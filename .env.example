# Database Configuration
POSTGRES_DB=obtv_studio
POSTGRES_USER=obtv_user
POSTGRES_PASSWORD=your_secure_password_here

# Application Configuration
DATABASE_URL=postgresql://obtv_user:your_secure_password_here@localhost:5432/obtv_studio
SESSION_SECRET=your_session_secret_here_minimum_32_characters

# Replit Auth Configuration (if using Replit authentication)
REPL_ID=your_repl_id
REPLIT_DOMAINS=your_domain.com
ISSUER_URL=https://replit.com/oidc

# PostgreSQL Connection Details
PGHOST=postgres
PGPORT=5432
PGDATABASE=obtv_studio
PGUSER=obtv_user
PGPASSWORD=your_secure_password_here

# Authentik SSO Configuration
AUTHENTIK_CLIENT_ID=your_client_id_here
AUTHENTIK_CLIENT_SECRET=your_client_secret_here
AUTHENTIK_ISSUER_URL=https://auth.yourdomain.com/application/o/your-app-slug

# Email (SendGrid) - used to send user invitation emails.
# Leave SENDGRID_API_KEY blank to disable email; admins can still copy invite
# links manually. SENDGRID_FROM_EMAIL must be a verified sender in SendGrid.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com

# Base URL used to build invite links in emails (e.g. https://studio.yourdomain.com).
# If left blank, the app derives it from the incoming request.
APP_BASE_URL=

# Optional: Logging
LOG_LEVEL=info